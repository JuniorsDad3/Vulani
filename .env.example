# Copy this file to ".env" in the same "functions" folder and fill
# in your REAL values there. The real ".env" file must never be
# committed to git — it's already listed in .gitignore for you.
#
# MAIL_PASSWORD is NOT set here — it's a Firebase "secret" instead,
# set with a command (see README-EMAIL-SETUP.txt), so it's encrypted
# by Firebase rather than sitting in a plain text file at all.

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-sending-address@gmail.com
ALERT_EMAIL=your-sending-address@gmail.com
